{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "allowJs": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@wta/contracts": ["packages/contracts/src/index.ts"],
      "@wta/contracts/*": ["packages/contracts/src/*"]
    }
  }
}
