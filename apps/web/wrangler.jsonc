{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "winner-takes-all-web",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "WTA_API_URL": "https://api.your-production-server.com"
  }
}
