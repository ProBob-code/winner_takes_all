generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  ADMIN
}

enum TournamentStatus {
  DRAFT
  OPEN
  FULL
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ParticipantStatus {
  REGISTERED
  ELIMINATED
  ADVANCED
  WINNER
  REFUNDED
}

enum MatchStatus {
  PENDING
  READY
  LIVE
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
}

enum WalletTransactionType {
  DEPOSIT
  ENTRY_FEE_DEBIT
  TOURNAMENT_PAYOUT
  REFUND
  MANUAL_ADJUSTMENT
}

model User {
  id                String              @id @default(cuid())
  name              String
  email             String              @unique
  passwordHash      String?
  walletBalance     Decimal             @default(0) @db.Decimal(12, 2)
  role              UserRole            @default(PLAYER)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  payments          Payment[]
  walletEntries     WalletTransaction[]
  participants      Participant[]
  matchesAsPlayer1  Match[]             @relation("match_player1")
  matchesAsPlayer2  Match[]             @relation("match_player2")
  matchesWon        Match[]             @relation("match_winner")
  leaderboardRecord Leaderboard?
}

model Tournament {
  id             String            @id @default(cuid())
  name           String
  entryFee       Decimal           @default(0) @db.Decimal(12, 2)
  prizePool      Decimal           @default(0) @db.Decimal(12, 2)
  maxPlayers     Int
  status         TournamentStatus  @default(DRAFT)
  mode           String            @default("online")
  game           String            @default("8ball")
  bracketType    String            @default("single_elimination")
  bracketState   Json?
  startsAt       DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  participants   Participant[]
  matches        Match[]
}

model Participant {
  id            String            @id @default(cuid())
  tournamentId  String
  userId        String
  seed          Int?
  status        ParticipantStatus @default(REGISTERED)
  joinedAt      DateTime          @default(now())
  tournament    Tournament        @relation(fields: [tournamentId], references: [id])
  user          User              @relation(fields: [userId], references: [id])

  @@unique([tournamentId, userId])
}

model Match {
  id            String       @id @default(cuid())
  tournamentId  String
  round         Int
  bracketSlot   String
  player1Id     String?
  player2Id     String?
  winnerId      String?
  roomCode      String?      @unique
  status        MatchStatus  @default(PENDING)
  startedAt     DateTime?
  completedAt   DateTime?
  resultMeta    Json?
  tournament    Tournament   @relation(fields: [tournamentId], references: [id])
  player1       User?        @relation("match_player1", fields: [player1Id], references: [id])
  player2       User?        @relation("match_player2", fields: [player2Id], references: [id])
  winner        User?        @relation("match_winner", fields: [winnerId], references: [id])
}

model Payment {
  id               String           @id @default(cuid())
  userId           String
  amount           Decimal          @db.Decimal(12, 2)
  currency         String           @default("USD")
  provider         PaymentProvider
  providerOrderId  String?          @unique
  providerEventId  String?          @unique
  idempotencyKey   String           @unique
  status           PaymentStatus    @default(PENDING)
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id])
}

model WalletTransaction {
  id               String                @id @default(cuid())
  userId           String
  paymentId        String?
  type             WalletTransactionType
  amount           Decimal               @db.Decimal(12, 2)
  balanceAfter     Decimal               @db.Decimal(12, 2)
  referenceType    String
  referenceId      String
  createdAt        DateTime              @default(now())
  user             User                  @relation(fields: [userId], references: [id])
}

model Leaderboard {
  userId        String   @id
  wins          Int      @default(0)
  losses        Int      @default(0)
  earnings      Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
}
