{
  "name": "winner-takes-all",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n api,web,site -c blue,green,magenta \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:site\"",
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run dev -w api",
    "dev:site": "npm run dev -w website",
    "build": "npm run build --workspaces --if-present",
    "build:site": "npm run build -w website",
    "build:web": "cd apps/web && npx opennextjs-cloudflare",
    "build:combined": "npm run build:site && npm run build:web && mkdir -p apps/web/.open-next/assets && cp -r apps/website/dist/* apps/web/.open-next/assets/",
    "deploy": "cd apps/website && npx wrangler deploy",
    "deploy:web": "cd apps/web && npx wrangler deploy",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
