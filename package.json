{
  "name": "winner-takes-all",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n api,frontend,site -c blue,green,magenta \"npm run dev:api\" \"npm run dev:frontend\" \"npm run dev:site\"",
    "dev:frontend": "npm run dev -w frontend",
    "dev:api": "npm run dev -w api",
    "dev:site": "npm run dev -w website",
    "build": "npm run build --workspaces --if-present",
    "build:site": "npm run build -w website",
    "build:frontend": "npm run build -w frontend",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
