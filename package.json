{
  "name": "winner-takes-all",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n api,frontend,site -c blue,green,magenta \"pnpm dev:api\" \"pnpm dev:frontend\" \"pnpm dev:site\"",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:api": "pnpm --filter api dev",
    "dev:site": "pnpm --filter website dev",
    "build": "pnpm -r build",
    "build:site": "pnpm --filter website build",
    "build:frontend": "pnpm --filter frontend build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@types/node": "^22.19.17",
    "concurrently": "^9.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
